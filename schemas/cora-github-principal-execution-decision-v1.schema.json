{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cora.github_principal_execution_decision.v1",
  "title": "Principal selection of one exact CORA protected execution",
  "type": "object",
  "required": [
    "schema",
    "decision_id",
    "principal",
    "scope",
    "issued_status",
    "eat_decision",
    "cora_refs",
    "workflow",
    "subjects",
    "execution",
    "validity",
    "non_claims",
    "supersedes",
    "predecessor"
  ],
  "properties": {
    "schema": {"const": "cora.github_principal_execution_decision.v1"},
    "decision_id": {"$ref": "#/$defs/safeId"},
    "principal": {
      "type": "object",
      "required": ["github_login", "github_user_id"],
      "properties": {
        "github_login": {"const": "jdr-cora-principal"},
        "github_user_id": {"const": 302294632}
      },
      "additionalProperties": false
    },
    "scope": {
      "type": "object",
      "required": ["gate_id", "authorization_id"],
      "properties": {
        "gate_id": {"const": "M1-DISTDET0-L3PAYLOAD0-EXEC0"},
        "authorization_id": {"$ref": "#/$defs/safeId"}
      },
      "additionalProperties": false
    },
    "issued_status": {"enum": ["granted", "denied"]},
    "eat_decision": {
      "type": "object",
      "required": ["path", "commit", "git_blob", "sha256", "message_id", "authority_level", "maturity_ceiling"],
      "properties": {
        "path": {"type": "string", "pattern": "^\\.codex/exchange/eat/decisions/[A-Za-z0-9._/-]+\\.md$"},
        "commit": {"$ref": "#/$defs/gitCommit"},
        "git_blob": {"$ref": "#/$defs/gitBlob"},
        "sha256": {"$ref": "#/$defs/sha256"},
        "message_id": {"$ref": "#/$defs/safeId"},
        "authority_level": {"const": "L3_candidate_payload_approval"},
        "maturity_ceiling": {"const": "candidate_payload_loaded_for_validation"}
      },
      "additionalProperties": false
    },
    "cora_refs": {
      "type": "object",
      "required": ["repair_commit", "request_commit", "decision_commit", "workflow_commit"],
      "properties": {
        "repair_commit": {"$ref": "#/$defs/gitCommit"},
        "request_commit": {"$ref": "#/$defs/gitCommit"},
        "decision_commit": {"$ref": "#/$defs/gitCommit"},
        "workflow_commit": {"$ref": "#/$defs/gitCommit"}
      },
      "additionalProperties": false
    },
    "workflow": {
      "type": "object",
      "required": [
        "repository",
        "workflow_id",
        "path",
        "git_blob",
        "sha256",
        "event",
        "ref",
        "head_sha",
        "run_id",
        "run_attempt",
        "run_name",
        "actor",
        "queued_at",
        "dispatch_inputs",
        "inputs_sha256"
      ],
      "properties": {
        "repository": {
          "type": "object",
          "required": ["full_name", "repository_id"],
          "properties": {
            "full_name": {"const": "jeffrinehart/cora"},
            "repository_id": {"const": 1267942116}
          },
          "additionalProperties": false
        },
        "workflow_id": {"type": "integer", "minimum": 1},
        "path": {"const": ".github/workflows/eat-reconsideration-preflight.yml"},
        "git_blob": {"$ref": "#/$defs/gitBlob"},
        "sha256": {"$ref": "#/$defs/sha256"},
        "event": {"const": "workflow_dispatch"},
        "ref": {"const": "refs/heads/core-main"},
        "head_sha": {"$ref": "#/$defs/gitCommit"},
        "run_id": {"type": "integer", "minimum": 1},
        "run_attempt": {"const": 1},
        "run_name": {"type": "string", "pattern": "^distdet-exec:[0-9a-f]{64}:[0-9a-f]{64}$"},
        "actor": {
          "type": "object",
          "required": ["github_login", "github_user_id"],
          "properties": {
            "github_login": {"const": "jeffrinehart"},
            "github_user_id": {"const": 115682297}
          },
          "additionalProperties": false
        },
        "queued_at": {"type": "string", "format": "date-time"},
        "dispatch_inputs": {
          "type": "object",
          "required": [
            "evaluation_mode",
            "candidate_head",
            "corpus_id",
            "base_head",
            "request_path",
            "manifest_path",
            "projection_path",
            "receipt_path",
            "authorization_id",
            "dispatch_nonce",
            "jit_runner_label"
          ],
          "properties": {
            "evaluation_mode": {"const": "distdet_validator_execution"},
            "candidate_head": {"$ref": "#/$defs/gitCommit"},
            "corpus_id": {"const": "EAT-RECONSIDERATION-PREFLIGHT0.ACTIVATION.v5"},
            "base_head": {"const": ""},
            "request_path": {"type": "string", "pattern": "^\\.codex/exchange/eat/requests/[A-Za-z0-9._-]+\\.md$"},
            "manifest_path": {"const": ""},
            "projection_path": {"const": ""},
            "receipt_path": {"const": ""},
            "authorization_id": {"$ref": "#/$defs/safeId"},
            "dispatch_nonce": {"$ref": "#/$defs/nonce"},
            "jit_runner_label": {"type": "string", "pattern": "^eat-distdet-[0-9a-f]{64}$"}
          },
          "additionalProperties": false
        },
        "inputs_sha256": {"$ref": "#/$defs/sha256"}
      },
      "additionalProperties": false
    },
    "subjects": {
      "type": "object",
      "required": ["candidate", "consumer_contract", "producer_profile", "payload"],
      "properties": {
        "candidate": {
          "type": "object",
          "required": ["repository", "commit"],
          "properties": {
            "repository": {"const": "jeffrinehart/cora"},
            "commit": {"$ref": "#/$defs/gitCommit"}
          },
          "additionalProperties": false
        },
        "consumer_contract": {
          "type": "object",
          "required": ["repository", "commit", "path", "git_blob", "sha256"],
          "properties": {
            "repository": {"const": "CORA"},
            "commit": {"$ref": "#/$defs/gitCommit"},
            "path": {"const": ".codex/contracts/m1-distdet0-l3payload0-consumer-contract.v1.json"},
            "git_blob": {"$ref": "#/$defs/gitBlob"},
            "sha256": {"$ref": "#/$defs/sha256"}
          },
          "additionalProperties": false
        },
        "producer_profile": {
          "type": "object",
          "required": ["repository", "evidence_commit", "profile_id", "profile_commit", "registry_path", "registry_git_blob", "registry_sha256"],
          "properties": {
            "repository": {"const": "SymMatAlg"},
            "evidence_commit": {"const": "57463e657c52cd1e3d79a888ee3dfdeb52e55a80"},
            "profile_id": {"const": "m1_distortion_detour_l3_payload_registered_reproduction_v2"},
            "profile_commit": {"const": "f7d965ad94bae0474b5659ab8d3a22fcc0ca4f7e"},
            "registry_path": {"const": "data/audit/cora_bridge/validator_profile_registry.v1.json"},
            "registry_git_blob": {"const": "697feb3d8a69e6ecbd2a8eb4b695c63837976e10"},
            "registry_sha256": {"const": "08b599f1c0fdf3966766196164dd3e6d92d8e1d5ee90f983b95c1a91283a7c64"}
          },
          "additionalProperties": false
        },
        "payload": {
          "type": "object",
          "required": ["repository", "source_commit", "bundle_commit", "evidence_commit", "path", "git_blob", "sha256"],
          "properties": {
            "repository": {"const": "SymMatAlg"},
            "source_commit": {"const": "43c972838d7ea0741a8c3ccb9fc970fa0fc04771"},
            "bundle_commit": {"const": "4cad6a43b528ae4fa2be75b89c402e7c02cfba41"},
            "evidence_commit": {"const": "57463e657c52cd1e3d79a888ee3dfdeb52e55a80"},
            "path": {"const": "data/audit/cora_bridge/golden/m1_distortion_detour_l3_payload_v1/m1_distortion_detour_reference_family.arrays.v1.npz"},
            "git_blob": {"const": "9292ec516f920fe03251ed7d45790836da4cc361"},
            "sha256": {"const": "767092a5206d75ece5e0b6a515749c6893e3cd53a28a260981d15a520696c989"}
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "execution": {
      "type": "object",
      "required": ["runner_image", "outer_observer_envelope_sha256", "control", "runner", "operator", "cleanup_authority"],
      "properties": {
        "runner_image": {
          "type": "object",
          "required": ["identity", "provenance_sha256", "sbom_sha256", "boot_evidence_sha256"],
          "properties": {
            "identity": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
            "provenance_sha256": {"$ref": "#/$defs/sha256"},
            "sbom_sha256": {"$ref": "#/$defs/sha256"},
            "boot_evidence_sha256": {"$ref": "#/$defs/sha256"}
          },
          "additionalProperties": false
        },
        "outer_observer_envelope_sha256": {"$ref": "#/$defs/sha256"},
        "control": {
          "type": "object",
          "required": ["kind", "identifier", "principal_selection_required"],
          "properties": {
            "kind": {"enum": ["github_environment", "principal_repository_execution_decision"]},
            "identifier": {"type": "string", "minLength": 1},
            "principal_selection_required": {"const": true}
          },
          "additionalProperties": false
        },
        "runner": {
          "type": "object",
          "required": ["repository_runner_id", "name", "jit_label", "required_labels"],
          "properties": {
            "repository_runner_id": {"type": "integer", "minimum": 1},
            "name": {"type": "string", "minLength": 1},
            "jit_label": {"type": "string", "pattern": "^eat-distdet-[0-9a-f]{64}$"},
            "required_labels": {
              "type": "array",
              "minItems": 5,
              "uniqueItems": true,
              "items": {"type": "string", "minLength": 1}
            }
          },
          "additionalProperties": false
        },
        "operator": {
          "type": "object",
          "required": ["github_login", "github_user_id"],
          "properties": {
            "github_login": {"const": "jeffrinehart"},
            "github_user_id": {"const": 115682297}
          },
          "additionalProperties": false
        },
        "cleanup_authority": {
          "type": "object",
          "required": ["token_subject_sha256", "permissions"],
          "properties": {
            "token_subject_sha256": {"$ref": "#/$defs/sha256"},
            "permissions": {
              "const": [
                "actions_variables:read",
                "actions_variables:delete",
                "actions_runners:read"
              ]
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "validity": {
      "type": "object",
      "required": ["issued_at", "expires_at", "use_count", "nonce"],
      "properties": {
        "issued_at": {"type": "string", "format": "date-time"},
        "expires_at": {"type": "string", "format": "date-time"},
        "use_count": {"const": 1},
        "nonce": {"$ref": "#/$defs/nonce"}
      },
      "additionalProperties": false
    },
    "non_claims": {
      "const": [
        "not an EAT decision or substitute for EAT authorization",
        "not payload acceptance or candidate_payload_validated",
        "not EAT hold clearance",
        "not trusted evaluator configuration",
        "not semantic subspace projector Gamma8 Hamiltonian or model-use authority",
        "not scientific claim acceptance or PR47 unblock"
      ]
    },
    "supersedes": {
      "type": "array",
      "maxItems": 1,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/safeId"}
    },
    "predecessor": {
      "oneOf": [
        {"type": "null"},
        {
          "type": "object",
          "required": ["decision_id", "record_sha256", "merge_commit"],
          "properties": {
            "decision_id": {"$ref": "#/$defs/safeId"},
            "record_sha256": {"$ref": "#/$defs/sha256"},
            "merge_commit": {"$ref": "#/$defs/gitCommit"}
          },
          "additionalProperties": false
        }
      ]
    }
  },
  "$defs": {
    "gitCommit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "gitBlob": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "nonce": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "safeId": {"type": "string", "pattern": "^[A-Za-z0-9._:-]{1,200}$"}
  },
  "additionalProperties": false
}
